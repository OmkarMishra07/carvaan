# JioSaavn API Configuration
VITE_JIOSAAVN_API_BASE=https://jiosavnapi-production.up.railway.app

# Firebase Web configuration (Frontend client)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_DATABASE_URL=your-firebase-realtime-database-url

# Vocal Separation Backend Service configuration (Backend server)
PORT=3001
REPLICATE_API_TOKEN=your-replicate-api-token
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-service-account-client-email
FIREBASE_PRIVATE_KEY="your-firebase-service-account-private-key-with-newlines-escaped"
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_TUNE_MODE_BACKEND_URL=http://localhost:3001
